# Hugging Face credentials
HF_USERNAME=Your Name
HF_BITNET_TOKEN=hf_your_token_here

# CUDA Toolkit — set to your CUDA installation path
# Find yours at: C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\
CUDA_PATH=C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v13.3
CUDA_HOME=C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v13.3
CUDA_ROOT=C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v13.3
CUDA_TOOLKIT_ROOT_DIR=C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v13.3
CUDARC_CUDA_VERSION=13.3

# MSVC compiler directory — required by nvcc on Windows to compile .cu files
# Find yours: C:\Program Files\Microsoft Visual Studio\<ver>\<edition>\VC\Tools\MSVC\<toolset>\bin\Hostx64\x64
NVCC_CCBIN=C:\Program Files\Microsoft Visual Studio\18\Enterprise\VC\Tools\MSVC\14.51.36231\bin\Hostx64\x64
